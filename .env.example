# 楽天ウェブサービス API（必須）
# https://webservice.rakuten.co.jp/ でアプリ登録し、アプリIDとアクセスキーを取得
RAKUTEN_APPLICATION_ID=your_application_id
RAKUTEN_ACCESS_KEY=your_access_key
# 任意: 楽天APIが要求する HTTP Referer。アプリ登録で「許可されたWebサイト」に一致させる。
# 未設定の場合は https://webservice.rakuten.co.jp/ を使います。
# RAKUTEN_REFERER=https://webservice.rakuten.co.jp/
# 任意: キーワード検索APIでアフィリエイト付きURLを得たい場合（Web UI の候補取得時）
# RAKUTEN_AFFILIATE_ID=your_affiliate_id

# 通知: LINE（Messaging API 推奨）
# Messaging API は、LINE Developers で作成したチャネルの「Channel access token」と
# 送信先（userId など）が必要です。
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_TO_USER_ID=your_line_to_user_id

# 通知: LINE Notify（互換）
# LINE Notify は 2025/03/31 に終了しています。
# まだトークンが残っている場合のみ動作する可能性があります。
LINE_NOTIFY_TOKEN=your_line_notify_token

# 通知: メール（任意・Gmail例）
# アプリパスワードを使用すること
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# NOTIFY_EMAIL=your_email@gmail.com
